# =============================================================================
# Shared / Database
# =============================================================================
# Neon pooled connection URL (for app runtime queries)
DATABASE_URL="postgresql://user:pass@ep-example-pooler.us-east-2.aws.neon.tech/mpp_voting?sslmode=require&pgbouncer=true"
# Neon direct connection URL (for Prisma migrations only)
DIRECT_URL="postgresql://user:pass@ep-example.us-east-2.aws.neon.tech/mpp_voting?sslmode=require"

# =============================================================================
# NestJS API (apps/api)
# =============================================================================
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
JWT_SECRET="change-me-to-a-random-64-character-string"
TZ="Asia/Kuala_Lumpur"

# Email (Nodemailer SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
# Optional: Resend API key (alternative to SMTP)
RESEND_API_KEY=

# =============================================================================
# Next.js Frontend (apps/web)
# =============================================================================
NEXT_PUBLIC_API_URL="http://localhost:3001"
